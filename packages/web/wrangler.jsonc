{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wp2astro",
  "compatibility_date": "2026-03-16",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "invocation_logs": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true
    }
  }
}
